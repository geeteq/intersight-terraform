# Local image file (tar, tar.gz, qcow2, vmdk) — skips Cisco download when set
# IMAGE_FILE=/path/to/intersight-appliance.tar

# Cisco Software Central API credentials (used when IMAGE_FILE is not set)
# Register at: https://apiconsole.cisco.com
CISCO_CLIENT_ID=your-client-id
CISCO_CLIENT_SECRET=your-client-secret
