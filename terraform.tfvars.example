cloud_name = "openstack"

# --- Appliance identity ---
hostname       = "intersight-appliance"
admin_password = "ChangeMe123!"   # initial admin password for the web UI

# --- Compute ---
image_name        = "intersight-appliance"   # base name; disks uploaded as intersight-appliance-1, -2, ...
flavor_name       = "8cpu-32G-0G"            # minimum 8 vCPU / 32GB RAM
availability_zone = "nova"                   # OpenStack availability zone

# One entry per disk — Intersight VA ships with 8 disks
disk_count = 8
disk_sizes = [500, 500, 500, 500, 500, 500, 500, 500]

# --- Network ---
management_network = "your-management-network"
floating_ip_pool   = ""   # set to external network name for a public IP

dns_servers = ["8.8.8.8", "8.8.4.4"]
ntp_servers = ["pool.ntp.org"]

# --- Security group ---
create_security_group = true
security_group_name   = "intersight-sg"

# --- Proxy (leave empty to disable) ---
proxy_host     = ""
proxy_port     = 3128
proxy_username = ""
proxy_password = ""
