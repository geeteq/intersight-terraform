#cloud-config
users:
  - name: ${baremetal_user}
    groups: [wheel]
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: true
    ssh_authorized_keys:
      - ${ssh_public_key}

package_update: true
package_upgrade: false

packages:
%{ for pkg in packages ~}
  - ${pkg}
%{ endfor ~}

runcmd:
  - echo 'Jumpbox provisioned by intersight-terraform' > /etc/motd
